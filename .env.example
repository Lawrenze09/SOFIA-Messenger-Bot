# ─────────────────────────────────────────────
# Sofia — Environment Variables
# Copy this file to .env and fill in your values.
# All variables marked REQUIRED must be set before the server starts.
# ─────────────────────────────────────────────


# ── Gemini ──────────────────────────────────
# REQUIRED — Google Gemini API key
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── Database ────────────────────────────────
# REQUIRED — TiDB Cloud connection string with SSL cert path
# Format: mysql+pymysql://user:pass@host:4000/db?ssl_ca=/path/to/cert.pem&ssl_verify_cert=true
# Render: set ssl_ca=/etc/secrets/isrgrootx1.pem and upload cert as a Secret File
MYSQL_URI=


# ── Cache / Session ──────────────────────────
# REQUIRED — Upstash Redis connection URL
# https://console.upstash.com
REDIS_URL=


# ── Notifications ────────────────────────────
# REQUIRED — SendGrid API key for admin alert emails
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# REQUIRED — Recipient email address for all admin alerts
ADMIN_EMAIL=


# ── Facebook Messenger ───────────────────────
# REQUIRED — Facebook App Secret for HMAC-SHA256 webhook verification
# Meta Developer Dashboard → Your App → Settings → Basic → App Secret
META_APP_SECRET=

# REQUIRED — Facebook App ID for filtering Sofia's own echo events
# Meta Developer Dashboard → Your App → Settings → Basic → App ID
META_APP_ID=

# REQUIRED — Facebook Page permanent access token
# Meta Developer Dashboard → Your App → Messenger → Settings → Access Tokens
PAGE_ACCESS_TOKEN=

# REQUIRED — Webhook verification token (any string you choose)
# Must match the value set in Meta Developer Dashboard → Webhooks → Verify Token
VERIFY_TOKEN=


# ── Pinecone ─────────────────────────────────
# OPTIONAL — RAG pipeline is disabled if these are not set
# https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX=


# ── Rate Limits ──────────────────────────────
# OPTIONAL — defaults shown
# RATE_LIMIT=30 per minute
# MSG_GAP_SECS=5
# SPAM_WINDOW_SECS=20
# SPAM_MAX_MSGS=10
# EMAIL_WINDOW_SECS=3600
# EMAIL_MAX=3


# ── TTLs ─────────────────────────────────────
# OPTIONAL — defaults shown
# DEDUP_TTL_SECS=300
# SESSION_TTL_SECS=7776000


# ── Flask ────────────────────────────────────
# OPTIONAL — set to development for local runs (uses in-memory rate limiter)
# FLASK_ENV=development
# PORT=5001
